{
  "name": "ante-social-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Ante Social — NestJS Microservices Backend",
  "scripts": {
    "build": "nest build api-gateway && nest build auth-service && nest build market-engine && nest build wallet-service && nest build notification-service && nest build websocket-gateway && nest build admin-service && nest build reputation-engine",
    "start": "node scripts/start-stack.js",
    "dev": "node scripts/dev-stack.js",
    "dev:all": "node scripts/dev-stack.js",
    "start:all": "node scripts/start-stack.js",
    "dev:gateway": "nest start api-gateway --watch",
    "dev:auth": "nest start auth-service --watch",
    "dev:market": "nest start market-engine --watch",
    "dev:wallet": "nest start wallet-service --watch",
    "dev:notification": "nest start notification-service --watch",
    "dev:ws": "nest start websocket-gateway --watch",
    "dev:admin": "nest start admin-service --watch",
    "dev:reputation": "nest start reputation-engine --watch",
    "lint": "nx run-many --target=lint --all",
    "test": "npm run test:unit && npm run test:e2e",
    "test:nx": "nx run-many --target=test --all",
    "test:unit": "node --test --require ts-node/register --require tsconfig-paths/register tests/unit/**/*.test.ts",
    "test:e2e": "node --test --require ts-node/register --require tsconfig-paths/register tests/e2e/**/*.e2e-spec.ts",
    "seed:admin": "ts-node -r tsconfig-paths/register scripts/seed-admin.ts",
    "seed:markets": "ts-node -r tsconfig-paths/register scripts/seed-markets.ts",
    "seed:all": "npm run seed:admin && npm run seed:markets",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/websockets": "^10.4.15",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.4.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.9.5",
    "nodemailer": "^8.0.1",
    "otplib": "^13.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@nx/js": "^20.4.0",
    "@nx/nest": "^20.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "nx": "^20.4.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
