NODE_ENV=development
WEBSOCKET_GATEWAY_PORT=3006
ENABLE_WS_KAFKA=false

DATABASE_URL=mongodb://localhost:27017/antesocial
REDIS_URL=redis://default:redispassword@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redispassword

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ante-social-websocket-gateway
KAFKA_CONSUMER_GROUP=ante-social-websocket-gateway-consumer
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_SUFFIX=.retry
KAFKA_DLQ_SUFFIX=.dlq

JWT_SECRET=<set-a-strong-random-secret-at-least-32-chars>
WS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

SENTRY_DSN=
