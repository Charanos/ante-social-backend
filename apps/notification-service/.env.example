NODE_ENV=development
NOTIFICATION_SERVICE_PORT=3005
NOTIFICATION_RPC_PORT=4005
ENABLE_NOTIFICATION_KAFKA=false

DATABASE_URL=mongodb://localhost:27017/antesocial
REDIS_URL=redis://default:redispassword@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redispassword

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ante-social-notification-service
KAFKA_CONSUMER_GROUP=ante-social-notification-service-consumer
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_SUFFIX=.retry
KAFKA_DLQ_SUFFIX=.dlq

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@antesocial.com

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=

SENTRY_DSN=
